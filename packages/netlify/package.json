{
	"name": "@vite-deploy/netlify",
	"version": "0.2.0",
	"description": "Deploy your Vite project to Netlify.",
	"type": "module",
	"sideEffects": false,
	"main": "./dist/index.js",
	"exports": {
		".": {
			"default": "./dist/index.js"
		},
		"./types": "./types.d.ts"
	},
	"files": [
		"dist",
		"types.d.ts"
	],
	"scripts": {
		"dev": "tsgo --build --force --watch",
		"build": "tsgo --build --force",
		"test": "node --test --test-reporter=spec --test-concurrency=1 --test-force-exit \"test/**/*.test.ts\""
	},
	"keywords": [
		"vite",
		"vite-plugin",
		"adapter",
		"netlify"
	],
	"author": "contact@florian-lefebvre.dev",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/web-runes/vite-deploy.git",
		"directory": "packages/netlify"
	},
	"bugs": "https://github.com/web-runes/vite-deploy/issues",
	"homepage": "https://vite-deploy.web-runes.dev",
	"license": "MIT",
	"peerDependencies": {
		"vite": "^8.0.0"
	},
	"devDependencies": {
		"@types/node": "^25.9.1",
		"@typescript/native-preview": "7.0.0-dev.20260524.1"
	},
	"dependencies": {
		"@netlify/functions": "^5.2.2",
		"@netlify/vite-plugin": "^2.12.6",
		"@vite-deploy/internal-helpers": "^0.2.0",
		"cookie-es": "^3.1.1",
		"srvx": "^0.11.16"
	}
}
