{
	"name": "@vite-deploy/vercel",
	"version": "0.0.4",
	"description": "Deploy your Vite project to Vercel.",
	"type": "module",
	"sideEffects": false,
	"main": "./dist/index.js",
	"exports": {
		".": {
			"default": "./dist/index.js"
		},
		"./types": "./types.d.ts"
	},
	"files": [
		"dist",
		"types.d.ts"
	],
	"scripts": {
		"dev": "tsgo --build --force --watch",
		"build": "tsgo --build --force",
		"test": "node --test --test-reporter=spec --test-concurrency=1 --test-force-exit \"test/**/*.test.ts\""
	},
	"keywords": [
		"vite",
		"vite-plugin",
		"adapter",
		"vercel"
	],
	"author": "contact@florian-lefebvre.dev",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/web-runes/vite-deploy.git",
		"directory": "packages/vercel"
	},
	"bugs": "https://github.com/web-runes/vite-deploy/issues",
	"homepage": "https://vite-deploy.web-runes.dev",
	"license": "MIT",
	"peerDependencies": {
		"vite": "^8.0.0"
	},
	"devDependencies": {
		"@types/node": "^25.6.2",
		"@typescript/native-preview": "7.0.0-dev.20260510.1"
	},
	"dependencies": {
		"@remix-run/node-fetch-server": "^0.13.1",
		"@vite-deploy/internal-helpers": "^0.1.1"
	}
}
