{
	"name": "root",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@11.3.0",
	"engines": {
		"node": ">=22.12.0"
	},
	"scripts": {
		"packages": "pnpm --filter '@vite-deploy/*' --parallel --stream",
		"changeset": "changeset",
		"lint": "biome check --write",
		"format": "biome format --write",
		"test": "pnpm --filter '@vite-deploy/*' test --if-present",
		"build": "pnpm --filter @vite-deploy/internal-helpers build && pnpm packages build",
		"ci:version": "changeset version && pnpm install --no-frozen-lockfile",
		"ci:publish": "changeset publish"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.15",
		"@changesets/cli": "2.31.0",
		"@changesets/changelog-github": "0.7.0",
		"pkg-pr-new": "0.0.75"
	}
}
